<script>
    // Tab switching logic
    function switchTab(tabName) {
        const upcomingCompContent = document.getElementById('upcoming-competitions-content');
        const clubEventsContent = document.getElementById('club-events-content');
        const pastHighlightsContent = document.getElementById('past-highlights-content');
        
        const upcomingCompBtn = document.getElementById('tab-upcoming-comp-btn');
        const clubBtn = document.getElementById('tab-club-btn');
        const pastBtn = document.getElementById('tab-past-btn');

        // Reset all buttons
        const allBtns = [upcomingCompBtn, clubBtn, pastBtn];
        allBtns.forEach(btn => {
            btn.classList.add('text-slate-500', 'font-medium', 'border-transparent');
            btn.classList.remove('text-primary', 'font-bold', 'border-primary');
        });

        // Hide all content
        const allContent = [upcomingCompContent, clubEventsContent, pastHighlightsContent];
        allContent.forEach(content => content.classList.add('hidden'));

        if (tabName === 'upcoming-competitions') {
            upcomingCompBtn.classList.add('text-primary', 'font-bold', 'border-primary');
            upcomingCompBtn.classList.remove('text-slate-500', 'font-medium', 'border-transparent');
            upcomingCompContent.classList.remove('hidden');
        } else if (tabName === 'club-events') {
            clubBtn.classList.add('text-primary', 'font-bold', 'border-primary');
            clubBtn.classList.remove('text-slate-500', 'font-medium', 'border-transparent');
            clubEventsContent.classList.remove('hidden');
        } else if (tabName === 'past-highlights') {
            pastBtn.classList.add('text-primary', 'font-bold', 'border-primary');
            pastBtn.classList.remove('text-slate-500', 'font-medium', 'border-transparent');
            pastHighlightsContent.classList.remove('hidden');
            
            // Trigger reveal animations
            document.querySelectorAll('#past-highlights-content .reveal-card').forEach(card => {
                revealObserver.observe(card);
            });
        }
    }

    // Intersection Observer for scroll reveal animations
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-card').forEach(card => {
        revealObserver.observe(card);
    });

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            const targetId = this.getAttribute('href');
            if (targetId === '#' || !targetId.startsWith('#')) return;
            
            e.preventDefault();
            const targetElement = document.querySelector(targetId);
            if (targetElement) {
                targetElement.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
</script>
